    "form-data": "*",
    "link-preview-js": "^3.1.0",
    "node-cache": "*",
    "node-fetch": "*",
    "node-webpmux": "^3.2.1",
    "pino": "^8.0.0",
    "pm2": "^5.3.0",
    "sqlite": "",
